{
  "manifest_version": 3,
  "name": "ScreenSnap — Hızlı Kayıt",
  "short_name": "ScreenSnap",
  "version": "1.0.0",
  "description": "Herhangi bir sayfadan ScreenSnap ile ekran kaydı başlat. Meeting tespiti ve hızlı paylaşım.",
  "permissions": ["activeTab", "scripting", "storage", "notifications", "tabs"],
  "host_permissions": [
    "https://meet.google.com/*",
    "https://teams.microsoft.com/*",
    "https://zoom.us/*",
    "https://*.webex.com/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16":  "icons/icon16.png",
      "48":  "icons/icon48.png",
      "128": "icons/icon128.png"
    },
    "default_title": "ScreenSnap Kaydı Başlat"
  },
  "icons": {
    "16":  "icons/icon16.png",
    "48":  "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": [
        "https://meet.google.com/*",
        "https://teams.microsoft.com/*",
        "https://zoom.us/*",
        "https://*.webex.com/*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
